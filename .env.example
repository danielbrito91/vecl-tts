# Example Environment Variables
# Copy this file to .env and fill in your own values.

# --- Paths ---
# Root directory for all model outputs, checkpoints, and logs
OUTPUT_PATH="tts-checkpoints-multilingual"
# Root directory where the training data is stored
DATASET_PATH="tts-dataset"

# --- S3 Configuration ---
# Name of the S3 bucket for cloud storage
S3_BUCKET_NAME="my-bucket"

# --- W&B Configuration ---
# Your personal or team's Weights & Biases entity
WANDB_ENTITY="my-wandb-entity"